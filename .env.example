# ── Database ──────────────────────────────────────────────────────────────
# Set DATABASE_URL to use PostgreSQL (required for Vercel).
# Leave empty/unset to use SQLite (local development).
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# SSL for PostgreSQL (default: true). Set to 'false' for local PG without SSL.
# DATABASE_SSL=false

# ── Owner account (seeded on first boot) ──────────────────────────────────
OWNER_EMAIL=owner@nebulous.local
OWNER_PASSWORD=Owner!2026
OWNER_FIRST_NAME=Owner
OWNER_LAST_NAME=Nebulous

# ── Session ───────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-string

# ── App URL ───────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-domain.vercel.app

# ── Stripe (optional) ────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── SMTP (optional — can also be configured via admin panel) ──────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
